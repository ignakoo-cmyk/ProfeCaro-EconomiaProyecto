# =============================================================================
# Ventana-Work — Variables de Entorno
# Copia este archivo como .env y ajusta los valores para tu entorno local.
# =============================================================================

# --- Base de Datos (PostgreSQL + PostGIS) ---
POSTGRES_USER=ventana
POSTGRES_PASSWORD=ventana_secret
POSTGRES_DB=ventana_db
DB_PORT=5432

# --- Backend (FastAPI) ---
BACKEND_PORT=8000
DATABASE_URL=postgresql://ventana:ventana_secret@db:5432/ventana_db
SECRET_KEY=dev-secret-key-change-in-production

# --- Lógica de Negocio ---
# Porcentaje de comisión de la plataforma (entero, ej: 10 = 10%)
PLATFORM_FEE_PERCENT=10

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000
